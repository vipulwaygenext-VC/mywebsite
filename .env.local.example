# ============================================================
# Vaktel — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ============================================================

# --- SMTP Configuration (Nodemailer) ----------------------------
#
# Option A: Gmail with App Password (recommended for quick setup)
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com > Security > App Passwords
#   3. Generate an App Password for "Mail"
#   4. Use the generated 16-char password as SMTP_PASS
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Vaktel Website" <your-gmail@gmail.com>

# Option B: Custom SMTP (e.g. Zoho, Hostinger, SendGrid SMTP)
# SMTP_HOST=smtp.zoho.in
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@vaktel.in
# SMTP_PASS=your-smtp-password
# SMTP_FROM="Vaktel Website" <noreply@vaktel.in>

# Option C: SendGrid SMTP relay
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.your-sendgrid-api-key
# SMTP_FROM="Vaktel Website" <noreply@vaktel.in>
